import "io"

func isDigit(ch: string) : bool {
    return ch == "0" || ch == "1" || ch == "2"
}

func digitToInt(ch: string) : int {
    let val = 0
    if(ch == "0") {
        val = 0
    } else {
        if(ch == "1") {
            val = 1
        } else {
            val = 2
        }
    }
    return val
}

print("Testing minimal digit functions")
print("Digit check: " + string(isDigit("1")))
print("Digit to int: " + string(digitToInt("1")))
print("Done")
