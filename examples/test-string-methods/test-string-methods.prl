import "io"

// Test string methods compilation

print("=== String Methods Compilation Test ===")

let greeting = "Hello World"
print("String: " + greeting)
print("Length: " + string(greeting.length()))
print("First char: " + greeting.charAt(0))
print("Word: " + greeting.substring(0, 5))
print("Index: " + string(greeting.indexOf("World")))

print("✅ String methods compiled successfully!")
