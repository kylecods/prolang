import "io"

struct Point {
    x: int;
    y: int;
}

struct Person {
    name: string;
    age: int;
}

func main(){
    let p: Point = Point { x: 10, y: 20 }
    print("p.x = " + p.x)
    print("p.y = " + p.y)

    p.x = 30
    print("p.x after mutation = " + p.x)

    let person: Person = Person { name: "John", age: 25 }
    print("person.name = " + person.name)
    print("person.age = " + person.age)

}