import "io"

// ===================================================================
// Phase B Implementation: String Methods in ProLang
// ===================================================================
//
// This file demonstrates the successful implementation of string methods:
// - length()  : Returns the length of a string
// - charAt()  : Gets character at index
// - substring(): Extracts substring [start, end)
// - indexOf() : Finds substring position (-1 if not found)
//
// These methods enable efficient text processing and JSON-like data handling
// ===================================================================

// === Practical Utility Functions using String Methods ===

func isWhitespace(ch: string) : bool {
    return ch == " " || ch == "\t" || ch == "\n" || ch == "\r"
}

func isDigit(ch: string) : bool {
    return ch == "0" || ch == "1" || ch == "2" || ch == "3" || ch == "4" ||
           ch == "5" || ch == "6" || ch == "7" || ch == "8" || ch == "9"
}

func skipWhitespace(json: string, pos: int) : int {
    while(pos < json.length()) {
        let ch = json.charAt(pos)
        if(!isWhitespace(ch)) {
            break
        }
        pos = pos + 1
    }
    return pos
}

func findClosingQuote(json: string, startPos: int) : int {
    let pos = startPos + 1

    while(pos < json.length()) {
        let ch = json.charAt(pos)
        if(ch == """") {
            return pos
        }
        pos = pos + 1
    }
    return -1
}

func extractQuotedString(json: string, startPos: int) : string {
    let closePos = findClosingQuote(json, startPos)
    if(closePos == -1) {
        return ""
    }
    return json.substring(startPos + 1, closePos)
}

// === Phase B Demonstration ===

print("================================================================================")
print("ProLang Phase B: String Methods Implementation")
print("================================================================================")
print("")

// Test 1: Basic String Methods
print("=== Test 1: Basic String Methods ===")
let greeting = "Hello World"
print("String: " + greeting)
print("  length(): " + string(greeting.length()))
print("  charAt(0): " + greeting.charAt(0))
print("  charAt(6): " + greeting.charAt(6))
print("  substring(0, 5): " + greeting.substring(0, 5))
print("  substring(6, 11): " + greeting.substring(6, 11))
print("  indexOf(World): " + string(greeting.indexOf("World")))
print("  indexOf(xyz): " + string(greeting.indexOf("xyz")))

// Test 2: String Methods Enable Text Analysis
print("")
print("=== Test 2: Text Analysis with String Methods ===")
let email = "user@example.com"
print("Email: " + email)
print("  Length: " + string(email.length()))
print("  @ position: " + string(email.indexOf("@")))
print("  Domain part: " + email.substring(5, 12))
print("  Domain index: " + string(email.indexOf("example")))

// Test 3: JSON-like Data Processing
print("")
print("=== Test 3: JSON-like Data Processing ===")
let jsonStr = "{name: Alice, age: 30}"
print("JSON: " + jsonStr)
print("  Contains name: " + string(jsonStr.indexOf("name") >= 0))
print("  Contains age: " + string(jsonStr.indexOf("age") >= 0))
print("  Name field position: " + string(jsonStr.indexOf("name")))
print("  Value position: " + string(jsonStr.indexOf("Alice")))

// Test 4: Character Classification
print("")
print("=== Test 4: Character Classification ===")
let text = "Hello123"
let idx = 0
while(idx < text.length()) {
    let ch = text.charAt(idx)
    let isWS = isWhitespace(ch)
    let isDig = isDigit(ch)
    print("  Position " + string(idx) + ": " + ch + " (ws: " + string(isWS) + ", digit: " + string(isDig) + ")")
    idx = idx + 1
}

// Test 5: String Utilities
print("")
print("=== Test 5: String Utilities ===")
let padded = "   hello"
print("Padded string: " + padded)
print("  After skipping whitespace, position: " + string(skipWhitespace(padded, 0)))

// Test 6: Data Structures
print("")
print("=== Test 6: Working with Data Structures ===")
let user = {}
user["username"] = "alice"
user["email"] = "alice@example.com"
user["verified"] = "true"
print("User: " + string(user["username"]))
print("Email: " + string(user["email"]))
print("Email domain: " + string(user["email"]).substring(6, 13))

let items = []
items.push("apple")
items.push("banana")
items.push("cherry")
print("Items: " + string(items.length()))
let pos = 0
while(pos < items.length()) {
    print("  - " + string(items[pos]))
    pos = pos + 1
}

