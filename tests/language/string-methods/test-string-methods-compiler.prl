import "io"

// Test string methods in compiler mode

print("=== String Methods Compiler Test ===")

let msg = "Hello World"
print("String: " + msg)
print("Length: " + string(msg.length()))
print("Char at 0: " + msg.charAt(0))
print("Substring (0, 5): " + msg.substring(0, 5))
print("Index of World: " + string(msg.indexOf("World")))

print("OK: String methods work in compiler mode!")
