import "io"

// Test Phase D2: else if syntax support

func testElseIf(value: int) : string {
    if(value == 1) {
        return "one"
    } else if(value == 2) {
        return "two"
    } else if(value == 3) {
        return "three"
    } else {
        return "other"
    }
}

print("=== Testing else if Syntax ===")
print("")

print("Test 1: value = 1")
print("Result: " + testElseIf(1))

print("Test 2: value = 2")
print("Result: " + testElseIf(2))

print("Test 3: value = 3")
print("Result: " + testElseIf(3))

print("Test 4: value = 5")
print("Result: " + testElseIf(5))

print("")
print("✅ Phase D2 - else if syntax works!")
